# Postgres connection string (Railway provides this automatically in prod)
DATABASE_URL=postgres://user:password@localhost:5432/desky?sslmode=disable

# HTTP port (Railway sets PORT automatically; defaults to 8080 locally)
PORT=8080

# OpenWeatherMap API key (free tier) — used by GET /widget/weather
OPENWEATHER_API_KEY=

# Last.fm — powers GET /widget/spotify (Now Playing, scrobbled from Apple Music)
# Get a key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_USERNAME=
